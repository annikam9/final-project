    viz3sub:"Ataques anuales contra defensores ambientales, 2012–2024. Altura = total. Colores = composición.",
    selectLabel:"Seleccionar país —",
    cardTotal:"Ataques totales",card2012:"Desde 2012",cardOC:"Participación del crimen organizado",
    cardPct:"% del total",cardInd:"Proporción Pueblos Indígenas",cardOCInd:"CO atacando indígenas",
    card2024:"Ataques en 2024",cardLatest:"Último año completo",
    cardPerp:"Principales perpetradores",cardOCI:"Índice de Crimen Organizado 2025",
    btnWorld:"Vista global",btnLatam:"Foco: América Latina",legendLabel:"Ataques (total) →",
    modeStacked:"Vista apilada",modeOC:"% CO",modeInd:"% indígenas",modeOCI:"CO sobre indígenas",
    methodBtn:"Metodología y Fuentes",
    methodText1:"[ Marcador — Fuentes de datos ]",methodText2:"[ Marcador — Metodología y limitaciones ]",
    footerText:"Datos: Front Line Defenders / Global Witness · ÍCO 2023 y 2025 (GI-TOC) · Caroline Chaffiotte, Fernanda Gandara Marchant y Annika Mösl",
    ttTotal:"Ataques totales",ttYear:"En 2024",
    criminality:"Criminalidad",resilience:"Resiliencia",since2023:"vs. 2023",
    stackNeither:"Otro / Desconocido",stackOC:"Solo crimen organizado",stackInd:"Víctimas indígenas",stackBoth:"CO + Indígenas",
    glossED:"Persona que, individual o colectivamente, actúa para promover o proteger los derechos humanos relacionados con el medio ambiente — tierra, agua, bosques y clima.",
    glossOC:"Redes criminales y grupos tipo mafia que usan la violencia, la corrupción y la intimidación para controlar economías ilegales — minería ilegal, tala, narcotráfico y acaparamiento de tierras.",
    titleHtml:`Cómo el <span class="gloss">Crimen Organizado<span class="gloss-tip"></span></span> <em>Amenaza</em> a los <span class="gloss">Defensores Ambientales<span class="gloss-tip"></span></span> en América Latina`,
    introP2:`Solo en Colombia, los <span class="gloss">defensores ambientales<span class="gloss-tip"></span></span> han sufrido más de 500 ataques registrados desde 2012. El <span class="gloss">crimen organizado<span class="gloss-tip"></span></span> ha sido identificado como perpetrador en una proporción creciente de esos ataques, especialmente desde 2023.`,
  }
};

let currentLang='en';
function t(k){return I18N[currentLang][k]||k;}

function applyGlossTips(el){
  // Assign correct glossary text to all .gloss-tip elements within el
  el.querySelectorAll('.gloss').forEach(g=>{
    const tip=g.querySelector('.gloss-tip');
    if(!tip)return;
    const txt=g.textContent.trim().toLowerCase();
    if(txt.includes('organized crime')||txt.includes('crimen organizado')||txt.includes('organised crime')){
      tip.textContent=t('glossOC');
    }else{
      tip.textContent=t('glossED');
    }
  });
}

function setLang(lang){
  currentLang=lang;
  document.querySelectorAll('#lang-switch button').forEach(b=>b.classList.remove('active'));
  document.querySelector(`#lang-switch button[onclick="setLang('${lang}')"]`).classList.add('active');
  document.querySelectorAll('[data-i18n]').forEach(el=>{
    el.textContent=t(el.getAttribute('data-i18n'));
  });
  // HTML elements
  document.getElementById('main-title').innerHTML=t('titleHtml');
  applyGlossTips(document.getElementById('main-title'));
  const ip2=document.querySelector('[data-i18n-html="introP2"]');
  if(ip2){ip2.innerHTML=t('introP2');applyGlossTips(ip2);}
  updateDashboard(document.getElementById('dashboard-country').value);
  updateChart(currentChartCountry);
  updateChartLegend();
}
</script>

<script>
function updateDashboard(country){
  const s=COUNTRY_STATS[country];if(!s)return;
  document.getElementById('d-total').textContent=s.total.toLocaleString();
  document.getElementById('d-oc').textContent=s.oc_share+'%';
  document.getElementById('d-ind').textContent=s.indigenous_share+'%';
  document.getElementById('d-oc-ind').textContent=s.oc_indigenous_share+'%';
  document.getElementById('d-2024').textContent=s.attacks_2024;

  const pb=document.getElementById('perp-bars');pb.innerHTML='';
  (PERP_DATA[country]||[]).forEach(p=>{
    pb.innerHTML+=`<div class="perp-row">
      <div class="perp-name">${p.label}</div>
      <div class="perp-track"><div class="perp-fill" style="width:${p.pct}%;background:${p.color}"></div></div>
      <div class="perp-pct">${p.pct}%</div></div>`;
  });

  const oc=OCI_DATA[country]||{};
  function arrow(v25,v23){
    if(v25==null||v23==null)return'';
    const d=v25-v23,a=Math.abs(d).toFixed(2);
    if(Math.abs(d)<0.05)return`<span class="oci-change flat">→ ${t('since2023')}</span>`;
    if(d>0)return`<span class="oci-change up">↑ +${a} ${t('since2023')}</span>`;
    return`<span class="oci-change dn">↓ −${a} ${t('since2023')}</span>`;
  }
  document.getElementById('oci-card').innerHTML=`
    <div class="oci-row">
      <div class="oci-header">
        <span class="oci-label">${t('criminality')}</span>
        <div class="oci-values"><span class="oci-score" style="color:#e74c3c">${oc.c25!=null?oc.c25.toFixed(2):'—'}/10</span>${arrow(oc.c25,oc.c23)}</div>
      </div>
      <div class="oci-track"><div class="oci-fill crim" style="width:${oc.c25?oc.c25*10:0}%"></div></div>
      <div class="oci-prev">2023: ${oc.c23!=null?oc.c23.toFixed(2):'—'}</div>
    </div>
    <div class="oci-row">
      <div class="oci-header">
        <span class="oci-label">${t('resilience')}</span>
        <div class="oci-values"><span class="oci-score" style="color:#1abc9c">${oc.r25!=null?oc.r25.toFixed(2):'—'}/10</span>${arrow(oc.r25,oc.r23)}</div>
      </div>
      <div class="oci-track"><div class="oci-fill res" style="width:${oc.r25?oc.r25*10:0}%"></div></div>
      <div class="oci-prev">2023: ${oc.r23!=null?oc.r23.toFixed(2):'—'}</div>
    </div>`;
}
</script>

<script>
const wdMap={};WORLD_DATA.forEach(d=>{wdMap[d.country]=d;});
const NAME_ALT={'United States of America':['United States','USA'],
  'Democratic Republic of the Congo':['Dem. Rep. Congo','Congo, Dem. Rep.'],
  'Türkiye':['Turkey','Turkiye']};
function matchName(n){for(const[k,v]of Object.entries(NAME_ALT)){if(v.includes(n)||n===k)return k;}return n;}
function attackColor(d){
  if(!d||d.total===0)return'#2a2a2a';
  if(d.total<=10)return'#5a2020';if(d.total<=30)return'#863020';
  if(d.total<=80)return'#b03828';if(d.total<=200)return'#c9392b';return'#ef4d3c';
}
let mapSvg,mapZoom,mapG,mapProj;

async function initMap(){
  const cont=document.getElementById('map-container');
  const W=cont.offsetWidth,H=Math.round(W*0.52);
  mapProj=d3.geoNaturalEarth1().scale(W/6.3).translate([W/2,H/2]);
  const path=d3.geoPath().projection(mapProj);
  mapSvg=d3.select('#world-map').attr('viewBox',`0 0 ${W} ${H}`).attr('width',W).attr('height',H);
  mapZoom=d3.zoom().scaleExtent([0.5,12]).on('zoom',e=>mapG.attr('transform',e.transform));
  mapSvg.call(mapZoom);
  mapG=mapSvg.append('g');
  mapG.append('rect').attr('width',W).attr('height',H).attr('fill','#181818');
  try{
    const world=await d3.json('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json');
    const feats=topojson.feature(world,world.objects.countries).features;
    mapG.selectAll('.country-path').data(feats).enter().append('path')
      .attr('class','country-path').attr('d',path)
      .attr('fill',d=>attackColor(wdMap[matchName((d.properties&&d.properties.name)||'')]))
      .on('mouseover',function(ev,d){
        const nm=(d.properties&&d.properties.name)||'Unknown';
        const data=wdMap[matchName(nm)];
        const tt=document.getElementById('map-tt');tt.style.display='block';
        tt.innerHTML=`<strong>${nm}</strong>
          <div class="tr"><span>${t('ttTotal')}:</span><span class="tv">${data?data.total:0}</span></div>
          <div class="tr"><span>${t('ttYear')}:</span><span class="tv">${data?data.attacks_2024:0}</span></div>`;
        posMapTT(ev,tt);
      })
      .on('mousemove',ev=>posMapTT(ev,document.getElementById('map-tt')))
      .on('mouseout',()=>{document.getElementById('map-tt').style.display='none';});
  }catch(e){
    const sz=d3.scaleSqrt().domain([0,509]).range([3,28]);
    mapG.selectAll('circle').data(WORLD_DATA).enter().append('circle')
      .attr('cx',d=>mapProj([d.lon,d.lat])[0]).attr('cy',d=>mapProj([d.lon,d.lat])[1])
      .attr('r',d=>sz(d.total)).attr('fill',d=>attackColor(d)).attr('fill-opacity',.85)
      .attr('stroke','rgba(255,255,255,.12)').attr('stroke-width',.5)
      .on('mouseover',function(ev,d){
        const tt=document.getElementById('map-tt');tt.style.display='block';
        tt.innerHTML=`<strong>${d.country}</strong>
          <div class="tr"><span>${t('ttTotal')}:</span><span class="tv">${d.total}</span></div>
          <div class="tr"><span>${t('ttYear')}:</span><span class="tv">${d.attacks_2024}</span></div>`;
        posMapTT(ev,tt);})
      .on('mousemove',ev=>posMapTT(ev,document.getElementById('map-tt')))
      .on('mouseout',()=>{document.getElementById('map-tt').style.display='none';});
  }
}
function posMapTT(ev,tt){
  const r=document.getElementById('map-container').getBoundingClientRect();
  let x=ev.clientX-r.left+12,y=ev.clientY-r.top-12;
  if(x+200>r.width)x-=212;if(y<0)y=0;
  tt.style.left=x+'px';tt.style.top=y+'px';
}
function zoomMap(view){
  document.getElementById('btn-world').classList.toggle('active',view==='world');
  document.getElementById('btn-latam').classList.toggle('active',view==='latam');
  if(!mapSvg||!mapProj)return;
  if(view==='latam'){
    const cont=document.getElementById('map-container');
    const W=cont.offsetWidth,H=Math.round(W*0.52);
    // Latin America bounding box lon -120..−34, lat −56..33
    const p1=mapProj([-120,33]),p2=mapProj([-34,-56]);
    if(!p1||!p2)return;
    const bx=Math.min(p1[0],p2[0]),by=Math.min(p1[1],p2[1]);
    const bw=Math.abs(p2[0]-p1[0]),bh=Math.abs(p2[1]-p1[1]);
    const scale=Math.min(W/bw,H/bh)*0.82;
    const tx=W/2-(bx+bw/2)*scale,ty=H/2-(by+bh/2)*scale;
    mapSvg.transition().duration(750).call(mapZoom.transform,d3.zoomIdentity.translate(tx,ty).scale(scale));
  }else{
    mapSvg.transition().duration(750).call(mapZoom.transform,d3.zoomIdentity);
  }
}
</script>

<script>
let currentChartMode='stacked',currentChartCountry='Colombia';
const SC={neither:'#3a3a3a',oc_only:'#e74c3c',ind_only:'#1abc9c',both:'#f39c12'};

function setChartMode(m){
  currentChartMode=m;
  ['stacked','oc','ind','oci'].forEach(x=>document.getElementById('mode-'+x).classList.toggle('active',x===m));
  updateChartLegend();updateChart(currentChartCountry);
}
function updateChartLegend(){
  const el=document.getElementById('chart-legend');
  if(currentChartMode==='stacked'){
    el.innerHTML=`<div class="cl-item"><div class="cl-dot" style="background:${SC.neither}"></div>${t('stackNeither')}</div>
      <div class="cl-item"><div class="cl-dot" style="background:${SC.oc_only}"></div>${t('stackOC')}</div>
      <div class="cl-item"><div class="cl-dot" style="background:${SC.ind_only}"></div>${t('stackInd')}</div>
      <div class="cl-item"><div class="cl-dot" style="background:${SC.both}"></div>${t('stackBoth')}</div>`;
  }else{
    const c={oc:'#e74c3c',ind:'#1abc9c',oci:'#f39c12'}[currentChartMode];
    const lbl={oc:t('modeOC'),ind:t('modeInd'),oci:t('modeOCI')}[currentChartMode];
    el.innerHTML=`<div class="cl-item"><div class="cl-dot" style="background:#3a3a3a"></div>${t('stackNeither')}</div>
      <div class="cl-item"><div class="cl-dot" style="background:${c}"></div>${lbl}</div>`;
  }
}
function updateChart(country){
  currentChartCountry=country;
  document.getElementById('chart-country').value=country;
  const data=TIMELINE[country];if(!data)return;
  const svg=d3.select('#bar-chart');svg.selectAll('*').remove();
  const W=svg.node().parentElement.offsetWidth||700,H=340;
  const m={top:16,right:20,bottom:38,left:42};
  const w=W-m.left-m.right,h=H-m.top-m.bottom;
  svg.attr('viewBox',`0 0 ${W} ${H}`).attr('width',W).attr('height',H);
  const g=svg.append('g').attr('transform',`translate(${m.left},${m.top})`);
  const xSc=d3.scaleBand().domain(data.map(d=>d.y)).range([0,w]).padding(.22);
  const maxT=Math.max(...data.map(d=>d.t),1);
  const ySc=d3.scaleLinear().domain([0,maxT]).range([h,0]).nice();
  g.selectAll('.gl').data(ySc.ticks(5)).enter().append('line')
    .attr('x1',0).attr('x2',w).attr('y1',d=>ySc(d)).attr('y2',d=>ySc(d)).attr('stroke','rgba(255,255,255,.04)');
  g.append('g').attr('transform',`translate(0,${h})`).call(d3.axisBottom(xSc))
    .call(ax=>{ax.select('.domain').remove();ax.selectAll('line').remove();
      ax.selectAll('text').attr('fill','#6a6050').attr('font-size','9.5px').attr('font-family','IBM Plex Mono,monospace').attr('dy','1.2em')});
  g.append('g').call(d3.axisLeft(ySc).ticks(5))
    .call(ax=>{ax.select('.domain').remove();ax.selectAll('line').remove();
      ax.selectAll('text').attr('fill','#6a6050').attr('font-size','9.5px').attr('font-family','IBM Plex Mono,monospace')});

  let tip=document.getElementById('chart-tip');
  if(!tip){tip=document.createElement('div');tip.id='chart-tip';
    tip.style.cssText='position:fixed;background:rgba(10,10,10,.97);border:1px solid rgba(255,255,255,.1);border-radius:4px;padding:10px 14px;font-size:.77rem;pointer-events:none;display:none;z-index:999;color:#a09880;line-height:1.7;min-width:160px';
    document.body.appendChild(tip);}

  if(currentChartMode==='stacked'){
    const segs=[{key:'neither',color:SC.neither,lbl:'stackNeither'},
      {key:'oc_only',color:SC.oc_only,lbl:'stackOC'},
      {key:'ind_only',color:SC.ind_only,lbl:'stackInd'},
      {key:'both',color:SC.both,lbl:'stackBoth'}];
    data.forEach(d=>{
      if(d.t===0)return;
      let y0=h;
      segs.forEach(seg=>{
        const n=d[seg.key]||0;if(n===0)return;
        const bh2=h-ySc(n),by2=y0-bh2;
        g.append('rect').attr('x',xSc(d.y)).attr('width',xSc.bandwidth())
          .attr('y',by2).attr('height',bh2).attr('fill',seg.color).attr('rx',1)
          .on('mouseover',function(ev){d3.select(this).attr('opacity',.7);tip.style.display='block';
            tip.innerHTML=`<strong style="color:#fff;font-family:'Playfair Display',serif">${d.y} · ${country}</strong><br>
              <span style="color:${SC.neither}">■</span> ${t('stackNeither')}: <b style="color:#fff">${d.neither}</b><br>
              <span style="color:${SC.oc_only}">■</span> ${t('stackOC')}: <b style="color:#fff">${d.oc_only}</b><br>
              <span style="color:${SC.ind_only}">■</span> ${t('stackInd')}: <b style="color:#fff">${d.ind_only}</b><br>
              <span style="color:${SC.both}">■</span> ${t('stackBoth')}: <b style="color:#fff">${d.both}</b><br>
              <span style="opacity:.5;font-size:.7rem">Total: ${d.t}</span>`;})
          .on('mousemove',ev=>{tip.style.left=(ev.clientX+12)+'px';tip.style.top=(ev.clientY-100)+'px';})
          .on('mouseout',function(){d3.select(this).attr('opacity',1);tip.style.display='none';});
        y0=by2;
      });
    });
  }else{
    const kMap={oc:'oc_n',ind:'ind_n',oci:'oci_n'};
    const cMap={oc:'#e74c3c',ind:'#1abc9c',oci:'#f39c12'};
    const pMap={oc:'oc_pct',ind:'ind_pct',oci:'oci_pct'};
    const sk=kMap[currentChartMode],col=cMap[currentChartMode],pk=pMap[currentChartMode];
    data.forEach(d=>{
      if(d.t===0)return;
      g.append('rect').attr('x',xSc(d.y)).attr('width',xSc.bandwidth())
        .attr('y',ySc(d.t)).attr('height',h-ySc(d.t)).attr('fill','#2a2a2a').attr('rx',1);
      const n=d[sk]||0;
      if(n>0){
        g.append('rect').attr('x',xSc(d.y)).attr('width',xSc.bandwidth())
          .attr('y',ySc(n)).attr('height',h-ySc(n)).attr('fill',col).attr('rx',1)
          .on('mouseover',function(ev){d3.select(this).attr('opacity',.7);tip.style.display='block';
            tip.innerHTML=`<strong style="color:#fff;font-family:'Playfair Display',serif">${d.y} · ${country}</strong><br>
              Total: <b style="color:#fff">${d.t}</b><br>
              Share: <b style="color:${col}">${n} (${d[pk]}%)</b>`;})
          .on('mousemove',ev=>{tip.style.left=(ev.clientX+12)+'px';tip.style.top=(ev.clientY-60)+'px';})
          .on('mouseout',function(){d3.select(this).attr('opacity',1);tip.style.display='none';});
      }
    });
  }
}
</script>

<script>
function toggleMethodology(){
  document.getElementById('method-btn').classList.toggle('open');
  document.getElementById('method-body').classList.toggle('open');
}
document.addEventListener('DOMContentLoaded',()=>{
  setLang('en');
  updateDashboard('Colombia');
  initMap();
  updateChartLegend();
  updateChart('Colombia');
  window.addEventListener('resize',()=>updateChart(currentChartCountry));
});
</script>
